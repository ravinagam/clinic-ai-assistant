# ── Database ──────────────────────────────────────────────
POSTGRES_DB=clinic
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://clinic_user:change_me_strong_password@postgres:5432/clinic

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── Clinic Config ─────────────────────────────────────────
CLINIC_NAME=City Health Clinic
CLINIC_PHONE=+91-9876543210
CLINIC_ADDRESS=123 Main Street, Chennai
CLINIC_HOURS=Monday-Saturday 9am-7pm
CLINIC_TIMEZONE=Asia/Kolkata

# ── Twilio (SMS / WhatsApp) ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1415xxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourclinic.com

# ── Google Calendar (optional) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ── Security ──────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_at_least_32_chars
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3003

# ── Frontend ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_CLINIC_NAME=City Health Clinic
